{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.ai/schemas/route-decision.schema.json",
  "title": "OpenClaw Route Decision",
  "description": "Frozen M12 route-law decision record for kinship classification, mediation, and deterministic reject receipts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "decisionId",
    "request",
    "requester",
    "target",
    "route",
    "decision",
    "trace",
    "receipts"
  ],
  "properties": {
    "kind": {
      "const": "route.decision"
    },
    "schemaVersion": {
      "const": 1
    },
    "decisionId": {
      "$ref": "#/definitions/namespacedId"
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requestId", "workId", "requestedAt", "summary", "artifactIntent"],
      "properties": {
        "requestId": {
          "$ref": "#/definitions/namespacedId"
        },
        "workId": {
          "$ref": "#/definitions/namespacedId"
        },
        "requestedAt": {
          "$ref": "#/definitions/timestamp"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 280
        },
        "artifactIntent": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "analysis",
              "code-change",
              "config-change",
              "docs",
              "evidence",
              "receipt",
              "test"
            ]
          }
        }
      }
    },
    "requester": {
      "$ref": "#/definitions/partyBinding"
    },
    "target": {
      "$ref": "#/definitions/partyBinding"
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requesterPresidentId",
        "targetPresidentId",
        "sharedPresident",
        "classification"
      ],
      "properties": {
        "requesterPresidentId": {
          "$ref": "#/definitions/namespacedId"
        },
        "targetPresidentId": {
          "$ref": "#/definitions/namespacedId"
        },
        "sharedPresident": {
          "type": "boolean"
        },
        "classification": {
          "type": "string",
          "enum": ["child", "sibling", "escalation", "cousin", "illegal"]
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "legal",
        "verdict",
        "requiresPresidentMediation",
        "mediationState",
        "cousinTicketRequired",
        "artifactReturnRequired",
        "rejectReasons"
      ],
      "properties": {
        "legal": {
          "type": "boolean"
        },
        "verdict": {
          "type": "string",
          "enum": ["allow", "reject"]
        },
        "requiresPresidentMediation": {
          "type": "boolean"
        },
        "mediationState": {
          "type": "string",
          "enum": ["not-required", "approved", "missing", "rejected"]
        },
        "cousinTicketRequired": {
          "type": "boolean"
        },
        "artifactReturnRequired": {
          "type": "boolean"
        },
        "rejectReasons": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "reject-binding-mismatch",
              "reject-classification-mismatch",
              "reject-missing-route-context",
              "reject-cross-president-direct-control",
              "reject-missing-president-mediation",
              "reject-missing-cousin-ticket",
              "reject-cousin-ticket-binding-mismatch",
              "reject-missing-artifact-return"
            ]
          }
        }
      }
    },
    "cousinTicket": {
      "$ref": "#/definitions/cousinTicketBinding"
    },
    "trace": {
      "$ref": "#/definitions/traceEnvelope"
    },
    "receipts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decisionDigest",
        "requesterLineageDigest",
        "requesterPolicyDigest",
        "targetLineageDigest",
        "targetPolicyDigest"
      ],
      "properties": {
        "decisionDigest": {
          "$ref": "#/definitions/sha256Digest"
        },
        "cousinTicketDigest": {
          "$ref": "#/definitions/sha256Digest"
        },
        "requesterLineageDigest": {
          "$ref": "#/definitions/sha256Digest"
        },
        "requesterPolicyDigest": {
          "$ref": "#/definitions/sha256Digest"
        },
        "targetLineageDigest": {
          "$ref": "#/definitions/sha256Digest"
        },
        "targetPolicyDigest": {
          "$ref": "#/definitions/sha256Digest"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "properties": {
              "legal": {
                "const": true
              }
            },
            "required": ["legal"]
          }
        }
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "verdict": {
                "const": "allow"
              },
              "rejectReasons": {
                "maxItems": 0
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "decision": {
            "properties": {
              "verdict": {
                "const": "reject"
              },
              "rejectReasons": {
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "route": {
            "properties": {
              "classification": {
                "const": "illegal"
              }
            },
            "required": ["classification"]
          }
        }
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "legal": {
                "const": false
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "route": {
            "properties": {
              "classification": {
                "const": "cousin"
              }
            },
            "required": ["classification"]
          },
          "decision": {
            "properties": {
              "legal": {
                "const": true
              }
            },
            "required": ["legal"]
          }
        }
      },
      "then": {
        "required": ["cousinTicket"],
        "properties": {
          "decision": {
            "properties": {
              "requiresPresidentMediation": {
                "const": true
              },
              "mediationState": {
                "const": "approved"
              },
              "cousinTicketRequired": {
                "const": true
              },
              "artifactReturnRequired": {
                "const": true
              }
            }
          },
          "receipts": {
            "required": [
              "decisionDigest",
              "cousinTicketDigest",
              "requesterLineageDigest",
              "requesterPolicyDigest",
              "targetLineageDigest",
              "targetPolicyDigest"
            ]
          }
        }
      }
    }
  ],
  "definitions": {
    "agentId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "namespacedId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
    },
    "sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "partyBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agentId",
        "role",
        "seatId",
        "seatKind",
        "lineageId",
        "lineageDigest",
        "runtimeId",
        "policyId",
        "registryNamespace",
        "recordKey",
        "traceNamespace",
        "receiptNamespace",
        "routeLawNamespace",
        "approvalNamespace"
      ],
      "properties": {
        "agentId": {
          "$ref": "#/definitions/agentId"
        },
        "role": {
          "type": "string",
          "enum": ["team-agent", "president"]
        },
        "seatId": {
          "$ref": "#/definitions/namespacedId"
        },
        "seatKind": {
          "type": "string",
          "enum": ["engineering", "ops", "product", "support"]
        },
        "lineageId": {
          "$ref": "#/definitions/namespacedId"
        },
        "lineageDigest": {
          "$ref": "#/definitions/sha256Digest"
        },
        "runtimeId": {
          "$ref": "#/definitions/namespacedId"
        },
        "policyId": {
          "$ref": "#/definitions/namespacedId"
        },
        "registryNamespace": {
          "$ref": "#/definitions/namespacedId"
        },
        "recordKey": {
          "$ref": "#/definitions/namespacedId"
        },
        "traceNamespace": {
          "$ref": "#/definitions/namespacedId"
        },
        "receiptNamespace": {
          "$ref": "#/definitions/namespacedId"
        },
        "routeLawNamespace": {
          "$ref": "#/definitions/namespacedId"
        },
        "approvalNamespace": {
          "$ref": "#/definitions/namespacedId"
        }
      }
    },
    "cousinTicketBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ticketId", "ticketDigest"],
      "properties": {
        "ticketId": {
          "$ref": "#/definitions/namespacedId"
        },
        "ticketDigest": {
          "$ref": "#/definitions/sha256Digest"
        }
      }
    },
    "traceEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "traceNamespace",
        "receiptNamespace",
        "routeLawNamespace",
        "approvalNamespace",
        "correlationId"
      ],
      "properties": {
        "traceNamespace": {
          "$ref": "#/definitions/namespacedId"
        },
        "receiptNamespace": {
          "$ref": "#/definitions/namespacedId"
        },
        "routeLawNamespace": {
          "$ref": "#/definitions/namespacedId"
        },
        "approvalNamespace": {
          "$ref": "#/definitions/namespacedId"
        },
        "correlationId": {
          "$ref": "#/definitions/namespacedId"
        }
      }
    }
  }
}

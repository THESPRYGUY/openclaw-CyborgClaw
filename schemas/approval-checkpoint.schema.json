{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.ai/schemas/approval-checkpoint.schema.json",
  "title": "OpenClaw M14 Approval Checkpoint",
  "description": "M14 approval checkpoint contract for approve, deny, or expire outcomes tied to artifact receipts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "checkpointId",
    "runId",
    "approvalPolicy",
    "outcome",
    "state",
    "recordedAt",
    "expiresAt",
    "artifactProfileId",
    "artifactIds",
    "trace"
  ],
  "properties": {
    "kind": {
      "const": "approval.checkpoint"
    },
    "schemaVersion": {
      "const": 1
    },
    "checkpointId": {
      "$ref": "#/definitions/namespacedId"
    },
    "runId": {
      "$ref": "#/definitions/namespacedId"
    },
    "approvalPolicy": {
      "type": "string",
      "enum": ["strict", "on-failure", "never"]
    },
    "outcome": {
      "type": "string",
      "enum": ["approve", "deny", "expire"]
    },
    "state": {
      "type": "string",
      "enum": ["approved", "denied", "expired"]
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280
    },
    "recordedAt": {
      "$ref": "#/definitions/timestamp"
    },
    "expiresAt": {
      "$ref": "#/definitions/timestamp"
    },
    "artifactProfileId": {
      "$ref": "#/definitions/namespacedId"
    },
    "artifactIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/namespacedId"
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "traceNamespace",
        "receiptNamespace",
        "routeLawNamespace",
        "approvalNamespace",
        "correlationId"
      ],
      "properties": {
        "traceNamespace": {
          "$ref": "#/definitions/namespacedId"
        },
        "receiptNamespace": {
          "$ref": "#/definitions/namespacedId"
        },
        "routeLawNamespace": {
          "$ref": "#/definitions/namespacedId"
        },
        "approvalNamespace": {
          "$ref": "#/definitions/namespacedId"
        },
        "correlationId": {
          "$ref": "#/definitions/namespacedId"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "approve"
          }
        },
        "required": ["outcome"]
      },
      "then": {
        "properties": {
          "state": {
            "const": "approved"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "deny"
          }
        },
        "required": ["outcome"]
      },
      "then": {
        "required": ["reason"],
        "properties": {
          "state": {
            "const": "denied"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "expire"
          }
        },
        "required": ["outcome"]
      },
      "then": {
        "required": ["reason"],
        "properties": {
          "state": {
            "const": "expired"
          }
        }
      }
    }
  ],
  "definitions": {
    "namespacedId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:/-]{2,255}$"
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    }
  }
}
